config {
    schema: "marts",
    type: "view",
    name: "ai_data_jobs"
}

select * FROM ${ref('ai_parsed_data_positions')}
where position_name is not null
AND REGEXP_CONTAINS(
    LOWER(position_name), 
          r'(햢햟햫햫|햢햟혝햟|data|sql|ml|ai|햟햫햟햩햦혝햦햨|analyst|dwh|dataops|scientist|혜햟햧햣햫혝햦혜혝|intelligence|analytics)'
  )
