config {
    type: "incremental",
    name: "ai_parsed_data",
    tags: ['incremental'],
    dependencies: ["merge_msgs"]

}


SELECT *
FROM
  AI.GENERATE_TABLE(
    MODEL ${ref('ai_parse_msg')},
    (
      SELECT
      -- тут должна бысть стейджинговая таблица которая фильттрует дата джобы и не подборки и не треш и желательно еще уникализирует по ембедингам
      -- если инррементал то берет Х новых
        '💼 Еженедельная подборка вакансий ☑️️ Java-разработчик – Y_LAB DEVELOPMENT Intern | Junior | Удаленная работа ☑️️ QA Engineer (Web) – Proxy.Market Junior | Middle | Удаленная работа ☑️️ Account-manager – Mymeet.ai Junior | Middle | Удаленная работа ☑️️ Сustomer support night – VPN проект Intern | Junior | Удаленная работа ➡️ Подписка на свежие вакансии в Telegram боте ➡️ Подписка на свежие вакансии в GeekLink ➡️ Все вакансии в GeekLink #ЕженедельнаяПодборка'
          AS prompt
    ),
    STRUCT("is_job_list BOOL, job_details ARRAY<STRUCT<role STRING, seniority_level STRING, has_rich_details BOOL, avg_usd_salary INT64, is_remote BOOL, technology_stack ARRAY<STRING>>>"
        AS output_schema, 8192 AS max_output_tokens))